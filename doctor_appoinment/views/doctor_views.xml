<odoo>
    <!--    Form view of Doctor-->
    <record id="patient_view_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <header>
                    <button type="object" name="action_view_appointments" class="oe_stat_button" icon="fa-calendar">
                        <field name="appointment_count" widget="statinfo"/>
                    </button>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="doctor_seq" readonly="1"/>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="specialization"/>
                            <field name="experience_years"/>
                            <field name="phone_number" widget="phone" placeholder="+91"/>
                            <field name="email" placeholder="abc@gmail.com"/>
                            <field name="consultation_fee"/>
                        </group>
                        <group>
                            <field name="image"/>
                            <field name="preview"/>
                            <div invisible="not preview" class="mt-2">
                                <field name="image" widget="image" readonly="1" options="{'size': [70, 80]}"
                                       class="oe_avatar"/>
                            </div>
                        </group>
                    </group>
 <!--                    <notebook>-->
<!--                        <page string="patients">-->
<!--                            <field name="patient_ids">-->
<!--                                <list>-->
<!--                                    <field name="name"/>-->
<!--                                    <field name="age"/>-->
<!--                                    <field name="gender"/>-->
<!--                                    <field name="phone_number"/>-->
<!--                                </list>-->
<!--                            </field>-->
<!--                        </page>-->
<!--                    </notebook>-->
                </sheet>
            </form>
        </field>
    </record>
    <!--    List view-->
    <record id="doctor_view_list" model="ir.ui.view">
        <field name="name">hospital.doctor.list</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list>
                <field name="doctor_seq" readonly="1"/>
                <field name="name"/>
                <field name="specialization"/>
                <field name="experience_years" optional="hide"/>
                <field name="phone_number" widget="phone" placeholder="+91"/>
                <field name="email" optional="hide"/>
                <field name="consultation_fee"/>
            </list>
        </field>
    </record>
    <!--Action Window-->
    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">doctor</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--  Menu item-->
    <!--    <menuitem id="menu_custom_root" name="Hospital Management D,A"/>-->
    <menuitem id="menu_hospital_doctor" name="Doctor" parent="patient_management.menu_my_custom_root"
              action="action_hospital_doctor"/>
</odoo>
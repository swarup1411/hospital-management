<odoo>
    <!--    form view of appointment-->
    <record id="hospital_appointment_view_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_done" type="object" string="Done"
                            invisible="state != 'confirm'" class="btn-success"/>
                     <button name="action_open_cancel_wizard" type="object" string="Cancel"
                            invisible="state in ('done','cancel')" class="btn-danger"/>
                    <button name="action_draft" type="object" string="draft"
                            invisible="state == 'draft'" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done"/>


                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="appointment_seq" readonly="1" placeholder="Apt/"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id" readonly="state != 'draft'"/>
                            <field name="patient_age" readonly="state != 'draft'"/>
                            <field name="doctor_id" readonly="state != 'draft'"/>
                            <field name="doctor_fees" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="time" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="reason" readonly="state != 'draft'"/>
                            <field name="add_note" readonly="state != 'draft'"/>
                        </group>

                    </group>
                </sheet>
            </form>

        </field>
    </record>
    <!--        List view for Appointment-->
    <record id="hospital_appointment_view_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list>

                <field name="appointment_seq" readonly="1"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="date"/>
                <field name="time"/>
                <field name="state"/>
                <field name="reason"/>
                <field name="doctor_fees"/>

            </list>
        </field>


    </record>

    <!--    Action Window-->
    <record id="action_appointment" model="ir.actions.act_window">
        <field name="name">appointment</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--    Menu Item-->
    <menuitem id="menu_appointment" name="Appointment" parent="patient_management.menu_my_custom_root"
              action="action_appointment"/>
</odoo>
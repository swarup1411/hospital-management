<odoo>
    <record id="view_appointment_cancel_wizard_form" model="ir.ui.view">
        <field name="name">appointment.cancel.wizard.form</field>
        <field name="model">appointment.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Appointment">
                 <group>
                   <div class="o_form_label">
                        Are you sure you want to cancel this appointment?
                    </div>
                </group>

                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Yes"
                            class="btn-danger"/>
                    <button string="No"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_cancel_appointment_wizard" model="ir.actions.act_window">
        <field name="name">appointment.cancel.wizard</field>
        <field name="res_model">appointment.cancel.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_appointment_cancel_wizard_form"/>
        <field name="target">new</field>
</record>

</odoo>

<odoo>
<!--    Sequence for doctor-->
    <record id="seq_doctor_seq" model="ir.sequence">
        <field name="name">doctor.seq</field>
        <field name="code">doctor.sequence</field>
        <field name="prefix">Doc/</field>
        <field name="padding">3</field>
    </record>
<!--    Sequence for appointment-->
    <record id="seq_appointment_seq" model="ir.sequence">
        <field name="name">appointment.seq</field>
        <field name="code">appointment.sequence</field>
        <field name="prefix">Apt/</field>
        <field name="padding">3</field>
    </record>

</odoo>
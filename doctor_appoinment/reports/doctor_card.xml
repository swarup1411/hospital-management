<odoo>
<!--    Pdf view of doctor-->
    <template id="report_my_doctor_receipt_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" style=" font-family: Arial; border:1px solid; border-radius:8px;">

                    <style>
                        .doctor_list_table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-top: 20px;
                        }
                        .doctor_list_table th {
                        background-color:#11a531;
                        color: white;
                        padding: 10px;
                        text-align: left;
                        font-weight: bold;
                        }
                        .doctor_list_table td {
                        padding: 8px 10px;
                        border-bottom: 1px solid #dee2e6;
                        }

                        .doctor_list_table tr:nth-child(even) {
                        background-color: #f2f9ff;
                        }

                        .low-opacity-bold {
                        font-weight: bold;
                        color: rgba(0, 0, 0, 0.5);
                        }
                    </style>
<!--                    Header-->
                    <div style="background:#11a531; color:white; padding:15px; text-align:center;
                                     font-size:23px; font-weight:bold;">
                        <h1>Hospital Doctor List</h1>
                    </div>

<!--                    Body-->

                    <div style="padding:15px">
                        <div style="font-size: 16px; background-color: #F8F9FA; color: rgba(0, 0, 0, 0.5); padding:20px; text-align: center;">
                            <p>Complete list of all doctors in the hospital</p>
                        </div>
                        <table class="doctor_list_table">
                            <thead>
                                <tr>
                                    <th>Doctor ID</th>
                                    <th>Name</th>
                                    <th>Specialization</th>
                                    <th>Experience</th>
                                    <th style="text-align: left;">Phone</th>
                                    <th style="text-align: center;">Consultation Fee</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="o">
                                    <tr>
                                        <td>
                                            <span class="fw-light" t-field="o.doctor_seq"/>
                                        </td>
                                        <td>
                                            <span class="low-opacity-bold" t-field="o.name"/>
                                        </td>
                                        <td>
                                            <span class="fw-light" t-field="o.specialization"/>
                                        </td>
                                        <td>
                                            <span class="low-opacity-bold" t-field="o.experience_years"/>
                                        </td>
                                        <td>
                                            <span class="fw-light" t-field="o.phone_number"/>
                                        </td>

                                        <td style="text-align: right;">
                                            <span class="fw-bold text-success" t-field="o.consultation_fee"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div class="mt-3 mb-2 fw-bold"
                             style="font-size: 18px; background-color: #E8F6F3; padding:20px; border-radius:8px; text-align: right;">
                            <span>
                                <strong>Total Doctors:</strong>
                            </span>
                            <span t-esc="len(docs)"/>
                        </div>
<!--                        Footer-->
                        <div class="text-center mt-3 mb-2 fw-bold">
                            <p style="font-size: 12px; background-color: #F8F9FA; color: rgba(0, 0, 0, 0.5); padding:20px; border-radius:8px;">
                                Hospital Management System
                            </p>
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
<odoo>
<!--    View for patient card pdf-->
    <template id="report_patient_details">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page"
                         style="border:2px solid #2c3e50; border-radius:8px;
                                font-family:Arial;">

<!--                              HEADER -->
                        <div style="background:#3a8dcf; color:white; padding:20px;
                                    text-align:center; font-size:26px; font-weight:bold;">
                            PATIENT REGISTRATION CARD
                        </div>

<!--                          PHOTO -->
                        <div style="width:90%;margin:30px auto; background:#eef6fb;
                                    height:130px; border-radius:10px; text-align:left;
                                     padding-left:10px;">

                            <t t-if="o.image">
                                <img t-att-src="'data:image/png;base64,%s' % (o.image.decode()
                                 if isinstance(o.image, bytes) else o.image)" style="height:120px;margin-top:5px;
                                 border-radius:8px;object-fit:cover;"/>
                            </t>
                            <t t-else="">
                                <div style="line-height:130px;
                                            font-size:14px;
                                            color:#777;">
                                    [Patient Photo - if available]
                                </div>
                            </t>

                        </div>
<!--                          Body  -->
                         <table style=" width:90%;margin:0 auto;border-collapse:collapse;font-size:20px;">
                            <tr style="height:60px;">
                                <td style="width:35%; padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Patient ID
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.patient_seq"/>
                                </td>
                            </tr>

                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Patient Name
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.name"/>
                                </td>
                            </tr>

                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Age
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.age"/>
                                    years
                                </td>
                            </tr>

                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Gender
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.gender"/>
                                </td>
                            </tr>

                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Blood Group
                                </td>
                                <td style="padding:12px; color:red; font-weight:bold;">
                                    <t t-esc="o.blood_group"/>
                                </td>
                            </tr>

                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Phone
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.phone_number"/>
                                </td>
                            </tr>
                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Email Id
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.email"/>
                                </td>
                            </tr>
                            <tr style="height:60px;">
                                <td style="padding:12px; color:#3a8dcf; font-weight:bold;">
                                    Total Appointments
                                </td>
                                <td style="padding:12px;">
                                    <t t-esc="o.appointment_count"/>
                                </td>
                            </tr>
                        </table>

<!--                         FOOTER -->
                        <div style="margin-top:40px;margin-bottom:30px;text-align:center;
                                    font-size:12px;color:#999;">
                            Hospital Management System
                        </div>

                    </div>
                </t>

            </t>
        </t>
    </template>
</odoo>

<odoo>
    <!--    Form view of doctor-->
    <record id="patient_view_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="patient_seq" readonly="1"/>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="date_of_birth" placeholder="00/00/0000"/>
                            <field name="age" readonly="1"/>
                            <field name="gender" widget="radio"/>
                             <field name="phone_number" widget="phone" placeholder="+91"/>
<!--                            <field name="doctor_id"/>-->
                            <field name="blood_group" widget="radio" options="{'horizontal':true}"/>

                        </group>
                        <group>
                            <field name="image"/>
                            <field name="preview"/>
                             <div invisible="not preview" class="mt-2">
                                <field name="image" widget="image" readonly="1" options="{'size': [70, 80]}"
                                       class="oe_avatar"/>
                            </div>

                            <field name="email" placeholder="abc1234@gmail.com" widget="email"/>
                            <field name="address" placeholder="Building Number: 300 , Street Name: Victoria Embankment
                                                                Street Address: Cleopatra's Needle
                                                                State: Greater London
                                                                City: London"/>
                        </group>
                    </group>
                </sheet>
              <chatter/>
            </form>
        </field>
    </record>


    <!--    List view-->
    <record id="patient_view_list" model="ir.ui.view">
        <field name="name">hospital.patient.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient_seq" readonly="1"/>
                <field name="name"/>
                <field name="age"/>
                <field name="gender" widget="badge" decoration-success="gender == 'male'"
                       decoration-warning="gender == 'female'" optional="hide"/>
                <field name="date_of_birth"/>
                <field name="phone_number"/>
                <field name="email"/>
            </list>
        </field>
    </record>
    <!--    Kanban view-->
    <record id="patient_view_kanban" model="ir.ui.view">
        <field name="name">hospital.patient.kanban</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="patient_seq"/>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone_number"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image me-3">
                                <field name="image" widget="image" class="img-fluid rounded" style="max-width: 80px; max-height: 80px;"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <field name="patient_seq"/>
                                </div>
                                <div class="o_kanban_tags">
                                    <span class="badge bg-primary">
                                        <field name="age"/> years
                                    </span>
                                    <span t-att-class="record.gender.raw_value === 'male' ? 'badge bg-success' : 'badge bg-warning'">
                                        <field name="gender"/>
                                    </span>
                                </div>
                                <div class="mt-2">
                                    <i class="fa fa-phone me-1"/>
                                    <field name="phone_number"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!--Action Window-->
    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">patient</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!--  Menu item-->
    <menuitem id="menu_my_custom_root" name="Hospital Management"/>
    <menuitem id="menu_hospital_patient" name="Patients" parent="menu_my_custom_root" action="action_hospital_patient"/>
</odoo>